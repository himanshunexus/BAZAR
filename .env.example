# ──────────────────────────────────────
# BAZAR — Environment Variables
# ──────────────────────────────────────
# Copy this file to .env and fill in real values.
#   cp .env.example .env

# Django core
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (SQLite for dev, PostgreSQL for prod)
DATABASE_URL=sqlite:///db.sqlite3
# DATABASE_URL=postgres://user:password@localhost:5432/localbazaarhub

# CSRF trusted origins (required for production — use your actual domain)
# CSRF_TRUSTED_ORIGINS=https://your-app.onrender.com

# Razorpay (stub — no real keys needed yet)
RAZORPAY_KEY_ID=rzp_test_xxxxx
RAZORPAY_KEY_SECRET=xxxxx

# Email (configure when needed)
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-app-password
